<!DOCTYPE html>
<html>
<head>
    <title>Product Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-5">

<h2 class="mb-4">Product Management</h2>
<div class="d-flex gap-2 mb-4">

<a href="/products" class="btn btn-outline-primary">
Products
</a>

<a href="/categories" class="btn btn-outline-secondary">
Categories
</a>

</div>


<!-- Add Product Form -->
<form action="/products" method="POST" class="row g-2 mb-4">

<div class="col-md-4">
<input type="text" name="productName" class="form-control" placeholder="Product Name" required>
</div>

<div class="col-md-4">
<select name="categoryId" class="form-select" required>

<% categories.forEach(cat => { %>

<option value="<%= cat.categoryId %>">
<%= cat.categoryName %>
</option>

<% }) %>

</select>
</div>

<div class="col-md-2">
<button class="btn btn-primary">Add Product</button>
</div>

</form>

<!-- Product Table -->
<table class="table table-bordered table-striped">

<thead class="table-dark">
<tr>
<th>ID</th>
<th>Product Name</th>
<th>Category ID</th>
<th>Category Name</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<% products.forEach(product => { %>

<tr>

<td><%= product.productId %></td>
<td><%= product.productName %></td>
<td><%= product.categoryId %></td>
<td><%= product.categoryName %></td>

<td>

<!-- Edit Form -->
<form action="/products/<%= product.productId %>?_method=PUT" method="POST" class="d-inline">

<input type="text" name="productName" value="<%= product.productName %>" class="form-control mb-1">

<select name="categoryId" class="form-select mb-1">

<% categories.forEach(cat => { %>

<option value="<%= cat.categoryId %>" <%= cat.categoryId === product.categoryId ? 'selected' : '' %>>
<%= cat.categoryName %>
</option>

<% }) %>

</select>

<button class="btn btn-warning btn-sm">Update</button>

</form>

<!-- Delete -->
<form action="/products/<%= product.productId %>?_method=DELETE" method="POST" class="d-inline">

<button class="btn btn-danger btn-sm">
Delete
</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

<!-- Pagination -->
<div class="mt-3">

<% if(page > 1){ %>
<a href="/products?page=<%= page - 1 %>" class="btn btn-secondary">Prev</a>
<% } %>

<span class="mx-2">Page <%= page %> of <%= totalPages %></span>

<% if(page < totalPages){ %>
<a href="/products?page=<%= page + 1 %>" class="btn btn-secondary">Next</a>
<% } %>

</div>

</body>
</html>